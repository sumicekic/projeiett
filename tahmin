   "source": [
    "#yolculuk\n",
    "yolculuk = pd.read_csv(\"ocak_Ayi.csv\", chunksize=chunk_size, parse_dates=[\"transition_date\"])\n",
    "\n",
    "birlesik_veri = []  #boş listeyi oluşturdu."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "22a6a36c",
   "metadata": {},
   "outputs": [],
   "source": [
    "for chunk in yolculuk:\n",
    "    chunk[\"tarih\"] = chunk[\"transition_date\"].dt.date\n",
    "\n",
    "    # trafik verisiyle birleştirdi.\n",
    "    chunk = pd.merge(chunk, trafik[[\"tarih\", \"average_traffic_index\"]], on=\"tarih\", how=\"left\")\n",
    "\n",
    "    # hava verisiyle birleştirdi.\n",
    "    hava_sutunları = [\"tarih\", \"temp\", \"humidity\", \"precip\", \"conditions\"]\n",
    "    chunk = pd.merge(chunk, hava[hava_sutunları], on=\"tarih\", how=\"left\")\n",
    "\n",
    "    # sonuçları listeye ekler\n",
    "    birlesik_veri.append(chunk)\n"
   ]
